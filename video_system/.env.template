# GCP Configuration Template
# Copy this file to .env and fill in your values
# Note: This is optional - you can also edit config.py directly

# Google Cloud Platform Settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET=your-gcp-bucket-name
GCP_CREDENTIALS_PATH=service-account-key.json
GCP_LOCATION=us-central1
GCP_STORAGE_CLASS=STANDARD

# Video Recording Settings
VIDEO_DEVICE=video=USB2.0 HD UVC WebCam
CLIP_DURATION=600
TIMEZONE=Asia/Kolkata
RECORD_START_TIME=13:00
RECORD_END_TIME=21:00

# Local Storage
BASE_DIR=recordings
